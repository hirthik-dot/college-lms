# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/college_lms
DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_lms
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-64-char-random-secret-string-here-min-32
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
